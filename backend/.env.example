# Database (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/financial_simulator

# Auth / JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Content (root of /content directory, relative to backend working dir)
CONTENT_DIR=../content
