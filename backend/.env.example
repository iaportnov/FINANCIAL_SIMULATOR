# Database (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/financial_simulator

# Auth / JWT
JWT_SECRET=dev-secret-change-me-32-bytes-minimum
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Content (root of /content directory, relative to backend working dir)
CONTENT_DIR=../content

# AI tutor (Anthropic Claude). Leave ANTHROPIC_API_KEY empty to disable the assistant.
ANTHROPIC_API_KEY=
TUTOR_MODEL=claude-opus-4-8
TUTOR_MAX_TOKENS=1024
